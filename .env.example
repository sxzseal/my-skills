# GitHub-backed skills storage
# PAT with `Contents: Read and write` scope on the GITHUB_REPO below.
# In dev, missing token is tolerated for READ operations (fs still works);
# write operations (POST/DELETE /api/skills) require this to be set.
GITHUB_TOKEN=""
GITHUB_OWNER="sxzseal"
GITHUB_REPO="my-skills"
GITHUB_BRANCH="main"

# Cloudflare Access defense-in-depth (defaults to on in prod, off in dev)
# ACCESS_AUTH_ENABLED="true"
