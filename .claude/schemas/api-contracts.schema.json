{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "API Contracts",
  "description": "Machine-readable API contract generated by dev-prd, consumed by dev-proto, dev-dev, dev-review, and dev-test",
  "type": "object",
  "required": ["generatedAt", "loopId", "endpoints"],
  "properties": {
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "loopId": {
      "type": "string",
      "pattern": "^loop-\\d{8}-\\d{3}$"
    },
    "endpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Endpoint"
      }
    }
  },
  "$defs": {
    "Endpoint": {
      "type": "object",
      "required": ["method", "path", "description", "response"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "path": {
          "type": "string",
          "pattern": "^/api/"
        },
        "description": {
          "type": "string"
        },
        "request": {
          "$ref": "#/$defs/Request"
        },
        "response": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ResponseBody"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ErrorResponse"
          }
        },
        "prdRef": {
          "type": "string"
        }
      }
    },
    "Request": {
      "type": "object",
      "properties": {
        "query": {
          "type": "array",
          "items": { "$ref": "#/$defs/Param" }
        },
        "body": {
          "type": "array",
          "items": { "$ref": "#/$defs/Param" }
        },
        "params": {
          "type": "array",
          "items": { "$ref": "#/$defs/Param" }
        }
      }
    },
    "Param": {
      "type": "object",
      "required": ["name", "type", "required"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "default": {},
        "description": { "type": "string" }
      }
    },
    "ResponseBody": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" }
      }
    },
    "ErrorResponse": {
      "type": "object",
      "required": ["status", "description"],
      "properties": {
        "status": { "type": "integer" },
        "description": { "type": "string" }
      }
    }
  }
}
